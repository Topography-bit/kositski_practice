<Window x:Class="TextEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TextEdit" Height="500" Width="600" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <ComboBox x:Name="FontCombo" Width="150" Margin="0,0,10,0" SelectionChanged="FontCombo_Changed">
                <ComboBoxItem Content="Arial" IsSelected="True"/><ComboBoxItem Content="Times New Roman"/>
                <ComboBoxItem Content="Courier New"/><ComboBoxItem Content="Consolas"/>
            </ComboBox>
            <ComboBox x:Name="SizeCombo" Width="80" SelectionChanged="SizeCombo_Changed">
                <ComboBoxItem Content="12"/><ComboBoxItem Content="14"/>
                <ComboBoxItem Content="16" IsSelected="True"/><ComboBoxItem Content="20"/><ComboBoxItem Content="24"/>
            </ComboBox>
        </StackPanel>
        <TextBox x:Name="EditorBox" Grid.Row="1" AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontSize="16" FontFamily="Arial" Padding="8"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Сохранить" Padding="20,8" Margin="0,0,10,0" Click="Save_Click"/>
            <Button Content="Открыть" Padding="20,8" Margin="0,0,10,0" Click="Open_Click"/>
            <Button Content="Очистить" Padding="20,8" Click="Clear_Click"/>
        </StackPanel>
    </Grid>
</Window>
